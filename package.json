{
  "name": "currant",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "ingest": "npm run ingest --workspace @currant/cli --",
    "shell": "npm run dev --workspace @currant/shell",
    "cash": "npm run dev --workspace @currant/cash",
    "web": "npm run dev --workspace @currant/cash",
    "health": "npm run dev --workspace @currant/health",
    "mind": "npm run dev --workspace @currant/mind",
    "build": "npm run build --workspace @currant/cash",
    "build:shell": "npm run build --workspace @currant/shell",
    "build:cash": "npm run build --workspace @currant/cash",
    "build:health": "npm run build --workspace @currant/health",
    "build:mind": "npm run build --workspace @currant/mind",
    "build:all": "npm run build:shell && npm run build:cash && npm run build:health && npm run build:mind && node scripts/assemble-dist.mjs",
    "generate:pwa": "node scripts/generate-pwa-assets.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
